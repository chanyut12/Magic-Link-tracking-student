{
  "name": "quasar-frontend",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "Quasar App",
  "author": "natthaphon2405 <natthaphonstb@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "node ./scripts/run-dev-with-mobile-url.mjs",
    "dev:plain": "quasar dev",
    "build": "quasar build",
    "verify:refactor-boundaries": "node ./scripts/verify-refactor-boundaries.mjs",
    "verify:routes": "node ./scripts/verify-route-contracts.mjs",
    "verify:auth-regression": "node ./scripts/verify-auth-regression.mjs",
    "verify:pinia-migration": "node ./scripts/verify-pinia-migration.mjs",
    "verify:frontend-gate": "npm run verify:refactor-boundaries && npm run verify:routes && npm run verify:auth-regression",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/cli": "^3.0.0",
    "@quasar/extras": "^1.16.4",
    "axios": "^1.13.6",
    "pinia": "^3.0.4",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "^2.1.0",
    "@types/node": "^20.5.9",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.4.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "prettier": "^3.3.3",
    "typescript": "^5.9.2",
    "vite-plugin-checker": "^0.11.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.7"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
